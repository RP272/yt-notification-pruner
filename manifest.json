{
    "name": "yt-notification-pruner",
    "description": "Google Chrome extension that removes shorts notifications from YouTube in Web application",
    "version": "1.0",
    "manifest_version": 3,
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": "images/logo.png"
    },
    "content_scripts": [
        {
            "js": [
                "scripts/content.js"
            ],
            "matches": [
                "http://www.youtube.com/*",
                "https://www.youtube.com/*"
            ]
        }
    ]
}